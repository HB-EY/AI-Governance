# PostgreSQL connection. Use either DATABASE_URL or the PG_* variables.
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_governance

# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=your_password_here
# PG_DATABASE=ai_governance

# Required: If your Postgres uses SCRAM-SHA-256 auth, set PG_PASSWORD to your user's password.
# Optional: connection pool size (default 10)
# PG_POOL_SIZE=10

# API service (packages/api)
# PORT=3000
# HOST=0.0.0.0
# LOG_LEVEL=info
# CORS_ORIGIN=https://admin.example.com

# Authentication: JWT secrets for agent and optional user/session tokens
# AGENT_JWT_SECRET=your-secret-for-signing-agent-keys
# USER_JWT_SECRET=your-secret-for-session-tokens
# JWT_SECRET=fallback-if-above-not-set

# S3-compatible evidence storage (optional)
# S3_BUCKET=ai-governance-evidence
# S3_REGION=us-east-1
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# OpenTelemetry (optional; set OTEL_SDK_DISABLED=true to disable)
# OTEL_SERVICE_NAME=ai-governance-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics

# Worker (packages/worker)
# WORKER_QUEUE=default
# WORKER_CONCURRENCY=2
# WORKER_HEALTH_PORT=3001
# WORKER_ID=worker-1
