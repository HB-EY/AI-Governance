# PostgreSQL connection. Use either DATABASE_URL or the PG_* variables.
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_governance

# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=your_password_here
# PG_DATABASE=ai_governance

# Required: If your Postgres uses SCRAM-SHA-256 auth, set PG_PASSWORD to your user's password.
# Optional: connection pool size (default 10)
# PG_POOL_SIZE=10
