{
  "name": "@ai-governance/client",
  "version": "0.1.0",
  "description": "Typed API client for Agent Governance Control Plane (generated from OpenAPI)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "generate": "openapi-ts -i ./openapi.json -o ./src/generated -c @hey-api/client-fetch",
    "clean": "rm -rf dist src/generated"
  },
  "dependencies": {
    "@ai-governance/shared": "file:../shared",
    "@hey-api/client-fetch": "^0.4.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.62.0",
    "typescript": "~5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
