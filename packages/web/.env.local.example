# Required: API base URL for the control plane backend (without trailing slash).
# Without this, dashboard and other API calls will 404 (they hit the Next server instead of the API).
# API runs on 3001, admin on 3000 in typical setup
NEXT_PUBLIC_API_URL=http://localhost:3001

# OAuth2/OIDC (admin console login)
# OAUTH_AUTHORIZATION_URL=https://your-idp.com/oauth2/v1/authorize
# OAUTH_TOKEN_URL=https://your-idp.com/oauth2/v1/token
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
# OAUTH_SCOPE=openid profile email

# Session (signing secret for session JWT; 8h expiry)
# SESSION_SECRET=your-secret-at-least-32-chars
